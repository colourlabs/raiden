{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug ExampleGame",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/src/EngineRuntime/EngineRuntime",
      "args": ["--datapack", "./games/ExampleGame/"],
      "cwd": "${workspaceFolder}/build",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
